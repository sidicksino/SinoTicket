{
  "expo": {
    "name": "SinoTicket",
    "slug": "SinoTicket",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icons/ios-light.png",
    "scheme": "sinoticket",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "icon": {
        "light": "./assets/icons/ios-light.png",
        "dark": "./assets/icons/ios-dark.png",
        "tinted": "./assets/icons/ios-tinted.png"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/icons/adaptive-icon.png",
        "monochromeImage": "./assets/icons/adaptive-icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.sidick102.SinoTicket"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/icons/ios-light.png"
    },
    "plugins": [
      "expo-router",
      "@clerk/expo",
      [
        "expo-splash-screen",
        {
          "image": "./assets/icons/splash.png",
          "resizeMode": "contain",
          "backgroundColor": "#1E88E5"
        }
      ],
      "expo-secure-store",
      "expo-web-browser",
      "expo-notifications",
      [
        "expo-media-library",
        {
          "photosPermission": "Allow SinoTicket to access your photos.",
          "savePhotosPermission": "Allow SinoTicket to save photos to your library.",
          "isAccessMediaLocationEnabled": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0a749316-1b99-4850-9fe5-b20eadedf7fd"
      }
    },
    "owner": "sidick102",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "locales": {
      "en": "./languages/en.json",
      "fr": "./languages/fr.json"
    },
    "updates": {
      "url": "https://u.expo.dev/0a749316-1b99-4850-9fe5-b20eadedf7fd"
    }
  }
}
